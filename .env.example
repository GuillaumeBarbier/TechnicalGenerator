# ============================================================
#  Configuration locale — COPIER ce fichier en ".env" et y mettre votre clé.
#  Le fichier .env est ignoré par git : la clé ne part JAMAIS sur GitHub.
# ============================================================

# Fournisseur IA : "openai" (ChatGPT) ou "anthropic" (Claude).
# Optionnel : si absent, OpenAI est choisi dès qu'OPENAI_API_KEY est présent.
AI_PROVIDER=openai

# --- OpenAI (ChatGPT) ---
OPENAI_API_KEY=sk-votre-cle-ici
# Modèle (optionnel, défaut : gpt-4o-mini) — ex : gpt-4o
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) — alternative ---
# ANTHROPIC_API_KEY=sk-ant-votre-cle-ici
# ANTHROPIC_MODEL=claude-opus-4-8

# Port du serveur (optionnel)
# PORT=3000
